# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PLEX_CLIENT_ID: Optional if you want a custom ID.
# PLEX_PRODUCT_NAME: Lesenacht (default)

# ACCESS_CODE: Optional shared secret to restrict access to a public instance.
# If set, users must visit the app with ?code=YOUR_CODE to gain access.
ACCESS_CODE="your_secret_here"

