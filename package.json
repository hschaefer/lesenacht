{
  "name": "lesenacht",
  "private": true,
  "version": "1.2.2",
  "lastUpdated": "2026-05-13",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:add": "npx cap add android",
    "cap:assets": "npx @capacitor/assets generate --android",
    "cap:deploy-android": "npm run build && npx cap sync && cd android && ./gradlew assembleDebug && adb uninstall io.lesenacht.app; adb install app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
