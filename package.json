    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.16.0",
